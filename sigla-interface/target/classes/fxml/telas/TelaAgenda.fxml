<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.com.sigla.interfacegrafica.controlador.ControladorAgenda"
      styleClass="screen-root">
    <children>
        <VBox styleClass="screen-header">
            <children>
                <Label text="Agenda e calendario" styleClass="screen-title-large"/>
                <Label fx:id="periodoLabel" text="-" styleClass="screen-subtitle"/>
            </children>
        </VBox>

        <VBox styleClass="content-card">
            <children>
                <HBox spacing="12.0">
                    <children>
                        <ComboBox fx:id="periodoCombo" prefWidth="140.0"/>
                        <DatePicker fx:id="dataReferenciaPicker" prefWidth="160.0"/>
                        <Button text="Novo evento" onAction="#onNovoEvento"/>
                        <Button text="Editar" onAction="#onEditarEvento"/>
                        <Button text="Reagendar" onAction="#onReagendar"/>
                        <Button text="Concluir" onAction="#onConcluir"/>
                        <Button text="Cancelar" onAction="#onCancelar"/>
                        <Button text="Atualizar" onAction="#onAtualizar"/>
                    </children>
                </HBox>

                <TableView fx:id="eventosTable" prefHeight="620.0">
                    <columns>
                        <TableColumn fx:id="dataColumn" text="Data" prefWidth="145.0"/>
                        <TableColumn fx:id="tituloColumn" text="Titulo" prefWidth="220.0"/>
                        <TableColumn fx:id="clienteColumn" text="Cliente" prefWidth="180.0"/>
                        <TableColumn fx:id="tipoColumn" text="Tipo" prefWidth="145.0"/>
                        <TableColumn fx:id="recorrenciaColumn" text="Recorrencia" prefWidth="120.0"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="110.0"/>
                        <TableColumn fx:id="prioridadeColumn" text="Prioridade" prefWidth="110.0"/>
                        <TableColumn fx:id="responsavelColumn" text="Responsavel" prefWidth="150.0"/>
                        <TableColumn fx:id="lembreteColumn" text="Lembrete" prefWidth="100.0"/>
                        <TableColumn fx:id="vinculoColumn" text="Vinculo" prefWidth="100.0"/>
                    </columns>
                </TableView>
            </children>
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
        </VBox>
    </children>
</VBox>
