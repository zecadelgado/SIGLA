<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.com.sigla.interfacegrafica.controlador.ControladorContratos"
      spacing="12.0" styleClass="screen-root">
    <children>
        <Label fx:id="title" styleClass="screen-title-large"/>
        <TextArea fx:id="summary" editable="false" wrapText="true" prefHeight="560.0"/>
    </children>
</VBox>
