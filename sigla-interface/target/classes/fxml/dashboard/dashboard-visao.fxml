<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      spacing="20" styleClass="dashboard-view">
    <children>
        <Label text="%dashboard.title" styleClass="dashboard-title"/>
        <Label text="%dashboard.subtitle" styleClass="dashboard-subtitle"/>
        <GridPane hgap="24" vgap="24" styleClass="dashboard-grid">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" minWidth="180" percentWidth="33.33"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="180" percentWidth="33.33"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="180" percentWidth="33.33"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="ALWAYS"/>
                <RowConstraints vgrow="ALWAYS"/>
            </rowConstraints>
            <children>
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="dashboard-card">
                    <children>
                        <Label text="%dashboard.card.operacao.title" styleClass="dashboard-card-title"/>
                        <Label text="%dashboard.card.operacao.body" styleClass="dashboard-card-body" wrapText="true"/>
                    </children>
                </VBox>
                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="dashboard-card">
                    <children>
                        <Label text="%dashboard.card.financeiro.title" styleClass="dashboard-card-title"/>
                        <Label text="%dashboard.card.financeiro.body" styleClass="dashboard-card-body" wrapText="true"/>
                    </children>
                </VBox>
                <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" styleClass="dashboard-card">
                    <children>
                        <Label text="%dashboard.card.clientes.title" styleClass="dashboard-card-title"/>
                        <Label text="%dashboard.card.clientes.body" styleClass="dashboard-card-body" wrapText="true"/>
                    </children>
                </VBox>
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="dashboard-card">
                    <children>
                        <Label text="%dashboard.card.servicos.title" styleClass="dashboard-card-title"/>
                        <Label text="%dashboard.card.servicos.body" styleClass="dashboard-card-body" wrapText="true"/>
                    </children>
                </VBox>
                <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="dashboard-card">
                    <children>
                        <Label text="%dashboard.card.estoque.title" styleClass="dashboard-card-title"/>
                        <Label text="%dashboard.card.estoque.body" styleClass="dashboard-card-body" wrapText="true"/>
                    </children>
                </VBox>
                <VBox GridPane.columnIndex="2" GridPane.rowIndex="1" styleClass="dashboard-card">
                    <children>
                        <Label text="%dashboard.card.cadastros.title" styleClass="dashboard-card-title"/>
                        <Label text="%dashboard.card.cadastros.body" styleClass="dashboard-card-body" wrapText="true"/>
                    </children>
                </VBox>
            </children>
        </GridPane>
    </children>
</VBox>
