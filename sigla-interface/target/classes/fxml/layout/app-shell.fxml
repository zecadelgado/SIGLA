<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.com.sigla.desktop.controller.AppShellController"
            prefWidth="1280" prefHeight="720">
    <left>
        <VBox spacing="10" prefWidth="250" styleClass="side-nav">
            <padding>
                <Insets top="20" right="16" bottom="20" left="16"/>
            </padding>
            <children>
                <Label text="SIGLA" styleClass="brand-title"/>
                <Label text="%app.subtitle" styleClass="brand-subtitle"/>
                <Button text="%menu.customers" onAction="#onCustomersClick" maxWidth="Infinity"/>
                <Button text="%menu.contracts" onAction="#onContractsClick" maxWidth="Infinity"/>
                <Button text="%menu.scheduling" onAction="#onSchedulingClick" maxWidth="Infinity"/>
                <Button text="%menu.services" onAction="#onServicesClick" maxWidth="Infinity"/>
                <Button text="%menu.finance" onAction="#onFinanceClick" maxWidth="Infinity"/>
                <Button text="%menu.inventory" onAction="#onInventoryClick" maxWidth="Infinity"/>
                <Button text="%menu.certificates" onAction="#onCertificatesClick" maxWidth="Infinity"/>
                <Button text="%menu.leads" onAction="#onLeadsClick" maxWidth="Infinity"/>
                <Button text="%menu.notifications" onAction="#onNotificationsClick" maxWidth="Infinity"/>
                <Button text="%menu.employees" onAction="#onEmployeesClick" maxWidth="Infinity"/>
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentHost" styleClass="content-host"/>
    </center>
</BorderPane>
