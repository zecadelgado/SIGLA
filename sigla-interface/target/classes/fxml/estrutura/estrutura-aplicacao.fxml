<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.estrutura.BorderPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.estrutura.StackPane?>
<?import javafx.scene.estrutura.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.com.sigla.interfacegrafica.controlador.ControladorEstruturaAplicacao"
            prefWidth="1280" prefHeight="720">
    <left>
        <VBox spacing="10" prefWidth="250" styleClass="side-nav">
            <padding>
                <Insets top="20" right="16" bottom="20" left="16"/>
            </padding>
            <children>
                <Label text="SIGLA" styleClass="brand-title"/>
                <Label text="%app.subtitle" styleClass="brand-subtitle"/>
                <Button text="%menu.clientes" onAction="#onClientesClick" maxWidth="Infinity"/>
                <Button text="%menu.contratos" onAction="#onContratosClick" maxWidth="Infinity"/>
                <Button text="%menu.agenda" onAction="#onSchedulingClick" maxWidth="Infinity"/>
                <Button text="%menu.servicos" onAction="#onServicesClick" maxWidth="Infinity"/>
                <Button text="%menu.financeiro" onAction="#onFinanceClick" maxWidth="Infinity"/>
                <Button text="%menu.estoque" onAction="#onInventoryClick" maxWidth="Infinity"/>
                <Button text="%menu.certificados" onAction="#onCertificadosClick" maxWidth="Infinity"/>
                <Button text="%menu.potenciaisclientes" onAction="#onPotencialClientesClick" maxWidth="Infinity"/>
                <Button text="%menu.notificacoes" onAction="#onNotificacaosClick" maxWidth="Infinity"/>
                <Button text="%menu.funcionarios" onAction="#onFuncionariosClick" maxWidth="Infinity"/>
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentHost" styleClass="content-host"/>
    </center>
</BorderPane>

