<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="790.0" prefWidth="1530.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.sigla.interfacegrafica.controlador.ControladorAgenda">
   <children>
      <BorderPane prefHeight="790.0" prefWidth="1530.0">
         <center>
            <VBox spacing="20.0" style="-fx-background-color: lightgrey;" BorderPane.alignment="CENTER">
               <padding>
                  <Insets bottom="30.0" left="28.0" right="40.0" top="30.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="20.0">
                     <children>
                        <VBox>
                           <children>
                              <Label text="Agenda" textFill="#00417e">
                                 <font><Font name="Ebrima Bold" size="46.0" /></font>
                              </Label>
                              <Label text="Eventos vinculados a clientes, contratos e ordens" textFill="#303030" />
                           </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#onNovoEvento" prefHeight="42.0" prefWidth="170.0" style="-fx-background-color: #0B2A6F; -fx-background-radius: 5;" text="+ Novo evento" textFill="WHITE" />
                     </children>
                  </HBox>
                  <TableView fx:id="agendaTable" prefHeight="590.0" prefWidth="1200.0">
                     <columns>
                        <TableColumn fx:id="clienteColumn" prefWidth="220.0" text="Cliente" />
                        <TableColumn fx:id="tituloColumn" prefWidth="280.0" text="Titulo" />
                        <TableColumn fx:id="tipoColumn" prefWidth="190.0" text="Tipo/Recorrencia" />
                        <TableColumn fx:id="dataColumn" prefWidth="150.0" text="Data" />
                        <TableColumn fx:id="statusColumn" prefWidth="140.0" text="Status" />
                        <TableColumn fx:id="prioridadeColumn" prefWidth="140.0" text="Prioridade" />
                     </columns>
                  </TableView>
               </children>
            </VBox>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
