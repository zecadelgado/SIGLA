<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.com.sigla.interfacegrafica.controlador.ControladorEstruturaAplicacao">
    <left>
        <VBox prefWidth="260.0" spacing="10.0" styleClass="shell-sidebar">
            <padding>
                <Insets top="24.0" right="18.0" bottom="18.0" left="18.0"/>
            </padding>
            <children>
                <Label text="Sigla" styleClass="shell-brand-title"/>
                <Label text="Gestao Empresarial" styleClass="shell-brand-subtitle"/>

                <Button text="Dashboard" maxWidth="Infinity" onAction="#onDashboardClick" styleClass="app-nav-button"/>
                <Button text="Cadastros" maxWidth="Infinity" onAction="#onCadastrosClick" styleClass="app-nav-button"/>
                <Button text="Clientes" maxWidth="Infinity" onAction="#onClientesClick" styleClass="app-nav-button"/>
                <Button text="Financeiro" maxWidth="Infinity" onAction="#onFinanceiroClick" styleClass="app-nav-button"/>
                <Button text="Servicos" maxWidth="Infinity" onAction="#onServicosClick" styleClass="app-nav-button"/>
                <Button text="Ordem de Servico" maxWidth="Infinity" onAction="#onOrdemServicoClick" styleClass="app-nav-button"/>
                <Button text="Estoque" maxWidth="Infinity" onAction="#onEstoqueClick" styleClass="app-nav-button"/>
                <Button text="Contratos" maxWidth="Infinity" onAction="#onContratosClick" styleClass="app-nav-button"/>
                <Button text="Certificados" maxWidth="Infinity" onAction="#onCertificadosClick" styleClass="app-nav-button"/>
                <Button text="Notificacoes" maxWidth="Infinity" onAction="#onNotificacoesClick" styleClass="app-nav-button"/>
                <Button text="Usuarios" maxWidth="Infinity" onAction="#onUsuariosClick" styleClass="app-nav-button"/>
                <Button text="Sair" maxWidth="Infinity" onAction="#onLogoutClick" styleClass="app-nav-button shell-logout-button"/>
            </children>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" pannable="true" hbarPolicy="NEVER">
            <content>
                <BorderPane fx:id="contentHost" styleClass="shell-content-host"/>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
