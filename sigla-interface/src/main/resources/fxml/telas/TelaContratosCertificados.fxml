<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.com.sigla.interfacegrafica.controlador.ControladorContratosCertificados"
      styleClass="screen-root">
    <children>
        <VBox styleClass="screen-header">
            <children>
                <Label text="Contratos e certificados" styleClass="screen-title-large"/>
                <Label text="Controle unico de vencimentos, alertas e validade dos certificados de higiene." styleClass="screen-subtitle" wrapText="true"/>
            </children>
        </VBox>

        <GridPane hgap="16.0" vgap="16.0" styleClass="metric-grid">
            <columnConstraints>
                <ColumnConstraints percentWidth="33.3"/>
                <ColumnConstraints percentWidth="33.3"/>
                <ColumnConstraints percentWidth="33.3"/>
            </columnConstraints>
            <children>
                <VBox GridPane.columnIndex="0" styleClass="metric-card">
                    <children>
                        <Label text="Ativos" styleClass="metric-label"/>
                        <Label fx:id="totalAtivosLabel" styleClass="metric-value"/>
                    </children>
                </VBox>
                <VBox GridPane.columnIndex="1" styleClass="metric-card">
                    <children>
                        <Label text="Proximos do vencimento" styleClass="metric-label"/>
                        <Label fx:id="proximosLabel" styleClass="metric-value"/>
                    </children>
                </VBox>
                <VBox GridPane.columnIndex="2" styleClass="metric-card">
                    <children>
                        <Label text="Vencidos" styleClass="metric-label"/>
                        <Label fx:id="vencidosLabel" styleClass="metric-value"/>
                    </children>
                </VBox>
            </children>
        </GridPane>

        <VBox styleClass="content-card">
            <children>
                <HBox spacing="12.0">
                    <children>
                        <ComboBox fx:id="filtroTipoCombo" prefWidth="180.0"/>
                        <ComboBox fx:id="filtroSituacaoCombo" prefWidth="240.0"/>
                        <Button text="Novo contrato" onAction="#onNovoContrato"/>
                        <Button text="Novo certificado" onAction="#onNovoCertificado"/>
                        <Button text="Atualizar" onAction="#onAtualizar"/>
                    </children>
                </HBox>

                <TableView fx:id="itensTable" prefHeight="520.0">
                    <columns>
                        <TableColumn fx:id="tipoColumn" text="Tipo" prefWidth="120.0"/>
                        <TableColumn fx:id="clienteColumn" text="Cliente" prefWidth="190.0"/>
                        <TableColumn fx:id="descricaoColumn" text="Descricao" prefWidth="230.0"/>
                        <TableColumn fx:id="inicioColumn" text="Inicio/Emissao" prefWidth="130.0"/>
                        <TableColumn fx:id="vencimentoColumn" text="Fim/Validade" prefWidth="130.0"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="115.0"/>
                        <TableColumn fx:id="alertaColumn" text="Alerta" prefWidth="95.0"/>
                        <TableColumn fx:id="detalheColumn" text="Valor/Intervalo" prefWidth="145.0"/>
                        <TableColumn fx:id="situacaoColumn" text="Situacao" prefWidth="120.0"/>
                    </columns>
                </TableView>
            </children>
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
        </VBox>
    </children>
</VBox>
