<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="790.0" prefWidth="1530.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.sigla.interfacegrafica.controlador.ControladorContratos">
   <children>
      <BorderPane prefHeight="790.0" prefWidth="1530.0">
         <center>
            <VBox spacing="20.0" style="-fx-background-color: lightgrey;" BorderPane.alignment="CENTER">
               <padding>
                  <Insets bottom="30.0" left="28.0" right="40.0" top="30.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="20.0">
                     <children>
                        <VBox>
                           <children>
                              <Label text="Contratos" textFill="#00417e">
                                 <font><Font name="Ebrima Bold" size="46.0" /></font>
                              </Label>
                              <Label text="Contratos vinculados aos clientes" textFill="#303030" />
                           </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#onNovoContrato" prefHeight="42.0" prefWidth="180.0" style="-fx-background-color: #0B2A6F; -fx-background-radius: 5;" text="+ Novo contrato" textFill="WHITE" />
                     </children>
                  </HBox>
                  <TableView fx:id="contratosTable" prefHeight="580.0" prefWidth="1200.0">
                     <columns>
                        <TableColumn fx:id="clienteColumn" prefWidth="220.0" text="Cliente" />
                        <TableColumn fx:id="descricaoColumn" prefWidth="260.0" text="Descricao" />
                        <TableColumn fx:id="tipoColumn" prefWidth="180.0" text="Tipo/Frequencia" />
                        <TableColumn fx:id="inicioColumn" prefWidth="130.0" text="Inicio" />
                        <TableColumn fx:id="fimColumn" prefWidth="130.0" text="Fim" />
                        <TableColumn fx:id="valorColumn" prefWidth="130.0" text="Valor mensal" />
                        <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Situacao" />
                     </columns>
                  </TableView>
               </children>
            </VBox>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
