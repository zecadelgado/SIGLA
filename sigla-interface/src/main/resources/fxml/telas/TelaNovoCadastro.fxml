<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="700.0" prefWidth="720.0" style="-fx-background-color: lightgrey;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.sigla.interfacegrafica.controlador.ControladorNovoCadastro">
   <content>
      <VBox spacing="14.0" style="-fx-background-color: lightgrey;">
         <padding>
            <Insets bottom="22.0" left="28.0" right="28.0" top="24.0" />
         </padding>
         <children>
            <Label text="Novo Cadastro" textFill="#00417e">
               <font>
                  <Font name="System Bold" size="40.0" />
               </font>
            </Label>

            <GridPane hgap="18.0" vgap="8.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                  <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
               </columnConstraints>
               <children>
                  <Label text="Tipo de Cadastro" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <ComboBox fx:id="tipoCombo" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-color: white; -fx-background-radius: 5;" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                  <Label text="Status do Funcionário" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  <ComboBox fx:id="statusFuncionarioCombo" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-color: white; -fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                  <Label text="Nome Completo" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                  <TextField fx:id="nomeField" maxWidth="Infinity" prefHeight="32.0" promptText="Nome do cliente ou funcionário" style="-fx-background-radius: 5;" GridPane.columnIndex="0" GridPane.rowIndex="3" />

                  <Label text="Cargo do Funcionário" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <TextField fx:id="cargoField" maxWidth="Infinity" prefHeight="32.0" promptText="Ex.: Técnico, Financeiro" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                  <Label text="CPF" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                  <TextField fx:id="cpfField" maxWidth="Infinity" prefHeight="32.0" promptText="Somente números" style="-fx-background-radius: 5;" GridPane.columnIndex="0" GridPane.rowIndex="5" />

                  <Label text="CNPJ" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  <TextField fx:id="cnpjField" maxWidth="Infinity" prefHeight="32.0" promptText="Somente números" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                  <Label text="Razão Social" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                  <TextField fx:id="razaoSocialField" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-radius: 5;" GridPane.columnIndex="0" GridPane.rowIndex="7" />

                  <Label text="Telefone" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                  <TextField fx:id="telefoneField" maxWidth="Infinity" prefHeight="32.0" promptText="DDD + número" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                  <Label text="E-mail" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                  <TextField fx:id="emailField" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-radius: 5;" GridPane.columnIndex="0" GridPane.rowIndex="9" />

                  <Label text="CEP" GridPane.columnIndex="1" GridPane.rowIndex="8" />
                  <TextField fx:id="cepField" maxWidth="Infinity" prefHeight="32.0" promptText="Somente números" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="9" />

                  <Label text="Rua" GridPane.columnIndex="0" GridPane.rowIndex="10" />
                  <TextField fx:id="ruaField" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-radius: 5;" GridPane.columnIndex="0" GridPane.rowIndex="11" />

                  <Label text="Número" GridPane.columnIndex="1" GridPane.rowIndex="10" />
                  <TextField fx:id="numeroField" maxWidth="Infinity" prefHeight="32.0" promptText="Somente números" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="11" />

                  <Label text="Complemento" GridPane.columnIndex="0" GridPane.rowIndex="12" />
                  <TextField fx:id="complementoField" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-radius: 5;" GridPane.columnIndex="0" GridPane.rowIndex="13" />

                  <Label text="Bairro" GridPane.columnIndex="1" GridPane.rowIndex="12" />
                  <TextField fx:id="bairroField" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="13" />

                  <Label text="Cidade" GridPane.columnIndex="0" GridPane.rowIndex="14" />
                  <TextField fx:id="cidadeField" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-radius: 5;" GridPane.columnIndex="0" GridPane.rowIndex="15" />

                  <Label text="Estado" GridPane.columnIndex="1" GridPane.rowIndex="14" />
                  <TextField fx:id="estadoField" maxWidth="Infinity" prefHeight="32.0" promptText="UF" style="-fx-background-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="15" />
               </children>
            </GridPane>

            <VBox spacing="6.0">
               <children>
                  <Label text="Observações" />
                  <TextField fx:id="observacoesField" maxWidth="Infinity" prefHeight="32.0" style="-fx-background-radius: 5;" />
               </children>
            </VBox>

            <Label fx:id="feedbackLabel" minHeight="22.0" textFill="#b00020" wrapText="true" />

            <HBox alignment="CENTER" spacing="24.0">
               <children>
                  <Button defaultButton="true" mnemonicParsing="false" onAction="#onCadastrar" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #0B2A6F; -fx-background-radius: 8;" text="Cadastrar" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font>
                  </Button>
                  <Button cancelButton="true" mnemonicParsing="false" onAction="#onCancelar" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 8;" text="Cancelar">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font>
                  </Button>
               </children>
               <VBox.vgrow>
                  <Priority fx:constant="NEVER" />
               </VBox.vgrow>
            </HBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
