<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.com.sigla.desktop.controller.AppShellController"
            prefWidth="1280" prefHeight="720">
    <top>
        <HBox spacing="8" styleClass="top-nav">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Button text="%menu.inventory" onAction="#onInventoryClick"/>
            <Button text="%menu.customer" onAction="#onCustomerClick"/>
            <Button text="%menu.billing" onAction="#onBillingClick"/>
            <Button text="%menu.notification" onAction="#onNotificationClick"/>
            <Button text="%menu.fiscal" onAction="#onFiscalClick"/>
        </HBox>
    </top>
    <center>
        <StackPane fx:id="contentHost" styleClass="content-host"/>
    </center>
</BorderPane>
